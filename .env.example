# PostgreSQL connection (TimescaleDB + PostGIS)
DATABASE_URL=postgresql://nhms:nhms_dev@localhost:5432/nhms

# S3-compatible object storage (MinIO in dev)
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET_NAME=nhms
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# Slurm Gateway backend: mock (default) or slurm
SLURM_GATEWAY_BACKEND=mock

# FastAPI port
API_PORT=8000
