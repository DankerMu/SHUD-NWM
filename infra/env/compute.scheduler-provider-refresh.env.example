# Node-22 DB-free scheduler file-provider refresh environment.
# Install as compute.scheduler-provider-refresh.env with mode 0600.
# Database and libpq selectors are intentionally forbidden by the wrapper.
NHMS_BASINS_ROOT=/volume/nwm/Basins
# Registry packages and all s3:// catalog/checkpoint references resolve against private compute storage.
OBJECT_STORE_ROOT=/scratch/frd_muziyao/nhms-prod/object-store
# Only the three canonical provider files publish through this shared-NFS root.
NHMS_SCHEDULER_PROVIDER_STORE_ROOT=/ghdc/data/nwm/object-store
OBJECT_STORE_PREFIX=s3://nhms
NHMS_SCHEDULER_REGISTRY_MANIFEST=/ghdc/data/nwm/object-store/scheduler/registry/manifest-last.json
# Slurm compute nodes intentionally read this private compute-visible mirror.
# A refresh is successful only when this mirror and the shared manifest above
# are the same prospective generation and have identical content SHA256.
NHMS_SLURM_SCHEDULER_REGISTRY_MANIFEST=/scratch/frd_muziyao/nhms-prod/object-store/scheduler/registry/manifest-last.json
NHMS_SCHEDULER_CANONICAL_READINESS_INDEX=/ghdc/data/nwm/object-store/scheduler/canonical-readiness/index-last.json
NHMS_SCHEDULER_STATE_INDEX=/ghdc/data/nwm/object-store/scheduler/state-index/index-last.json
NHMS_SCHEDULER_PROVIDER_REFRESH_WORK_ROOT=/scratch/frd_muziyao/nhms-prod/workspace/provider-refresh/runs
NHMS_SCHEDULER_PROVIDER_REFRESH_RECEIPT_ROOT=/scratch/frd_muziyao/nhms-prod/workspace/provider-refresh/receipts
NHMS_SCHEDULER_PROVIDER_REFRESH_EMERGENCY_ROOT=/scratch/frd_muziyao/nhms-prod/workspace/provider-refresh/emergency
NHMS_SCHEDULER_PROVIDER_REFRESH_LOCK=/scratch/frd_muziyao/nhms-prod/workspace/provider-refresh/refresh
