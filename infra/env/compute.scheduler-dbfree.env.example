# Node-22 DB-free scheduler EnvironmentFile template.
#
# Copy to /scratch/frd_muziyao/NWM/infra/env/compute.scheduler-dbfree.env on
# node-22, set mode 0600, and reference from the systemd user unit
# nhms-compute-scheduler.service via EnvironmentFile=.
#
# The scheduler daemon here is the production runner
#   `nhms-pipeline plan-production --continuous --submit`
# which drives services/orchestrator/scheduler.py run_continuous with a strict
# DB-free contract: no DATABASE_URL / PIPELINE_DATABASE_URL is inherited and all
# lock/state/journal/registry/readiness surfaces are file-backed on the shared
# NFS object-store or local scratch. See receipts/
# 2026-06-28-node22-dbfree-scheduler-live-proof.md (line 15 for the on-node
# path, line 51 for the systemd EnvironmentFile= binding) as the source-of-truth
# reference for this template. Design rationale: OpenSpec change
# `instrument-node22-scheduler-pass-timing` decision D8.

# --- DB-free contract gate --------------------------------------------------
# When true, the scheduler refuses to start if DATABASE_URL is set or if any
# backend other than `file` is requested; this fails-closed against silent
# regressions to a DB-coupled path.
NHMS_SCHEDULER_DB_FREE_REQUIRED=true

# --- File-backed lock ------------------------------------------------------
# Root directory holding per-pass advisory lock files. Should live on a
# filesystem shared with the systemd unit user, not on NFS if flock RPC is
# unreliable (use NHMS_SCHEDULER_FILE_LOCK_GUARD_MODE=atomic on such mounts).
NHMS_SCHEDULER_LOCK_ROOT=/scratch/frd_muziyao/nhms-production/workspace/scheduler/locks
NHMS_SCHEDULER_LOCK_BACKEND=file

# --- File-backed state / registry / journal --------------------------------
# All scheduler runtime surfaces are file-backed. The manifests/indexes point
# at the shared NFS object-store so node-27 (or any lab peer) can observe the
# scheduler's declared state without a DB round-trip.
NHMS_SCHEDULER_STATE_BACKEND=file
NHMS_SCHEDULER_REGISTRY_BACKEND=file
NHMS_SCHEDULER_REGISTRY_MANIFEST=/scratch/frd_muziyao/nhms-production/object-store/scheduler/registry/manifest-last.json
NHMS_SCHEDULER_CANONICAL_READINESS_BACKEND=file
NHMS_SCHEDULER_CANONICAL_READINESS_INDEX=/scratch/frd_muziyao/nhms-production/object-store/scheduler/canonical-readiness/index-last.json
NHMS_SCHEDULER_JOURNAL_BACKEND=file
NHMS_SCHEDULER_JOURNAL_ROOT=/scratch/frd_muziyao/nhms-production/workspace/scheduler/journal
NHMS_SCHEDULER_STATE_INDEX_BACKEND=file
NHMS_SCHEDULER_STATE_INDEX=/scratch/frd_muziyao/nhms-production/object-store/scheduler/state-index/index-last.json

# --- Evidence + runtime + tmp roots ----------------------------------------
# Per-pass evidence artefacts land under EVIDENCE_ROOT (see the retention timer
# below for bounded growth). RUNTIME_ROOT and TEMP_ROOT are scheduler-owned
# scratch surfaces; the retention script does NOT touch them.
NHMS_SCHEDULER_EVIDENCE_ROOT=/scratch/frd_muziyao/nhms-production/workspace/scheduler/evidence
NHMS_SCHEDULER_RUNTIME_ROOT=/scratch/frd_muziyao/nhms-production/runtime
NHMS_SCHEDULER_TEMP_ROOT=/scratch/frd_muziyao/nhms-production/tmp

# --- Filesystem allow-list -------------------------------------------------
# Colon-separated set of roots the scheduler is permitted to read/write.
# Any path outside this list is rejected by preflight before any Slurm work.
NHMS_SCHEDULER_ALLOWED_ROOTS=/scratch/frd_muziyao/nhms-production/workspace:/scratch/frd_muziyao/nhms-production/object-store:/scratch/frd_muziyao/nhms-production/runtime:/scratch/frd_muziyao/nhms-production/tmp:/ghdc/data/nwm/object-store:/var/lib/nhms/published

# --- Business scope --------------------------------------------------------
# Comma-separated forecast sources the scheduler considers each pass.
NHMS_SCHEDULER_SOURCES=gfs,IFS

# Bound source/cycle cohort submission and polling control threads only. The
# current 18-model registry becomes one 18-task Slurm array per source/cycle;
# the global array bound below plus resource-profile max_concurrent own compute.
NHMS_SCHEDULER_CONCURRENT_SUBMIT_BOUND=4
# Strict aggregate ceiling across Slurm arrays submitted by one scheduler pass.
NHMS_SCHEDULER_SLURM_ARRAY_CONCURRENCY_BOUND=32
NHMS_SCHEDULER_RECONCILE_ABSENCE_SECONDS=300
NHMS_SCHEDULER_RECONCILE_SLURM_USER=frd_muziyao
NHMS_SCHEDULER_RECONCILE_SLURM_ACCOUNT=replace-with-node22-slurm-account
NHMS_SCHEDULER_REQUIRE_DIRECT_GRID=true

# Comma-separated UTC hours (0-23) that are eligible business cycle boundaries.
# The scheduler hard-gates on this list; adapter cycle-hour env only narrows
# provider probes.
NHMS_SCHEDULER_ALLOWED_CYCLE_HOURS_UTC=0,12

# Leave NHMS_SCHEDULER_MODEL_IDS empty in production so the DB-free file
# registry drives every active Basins model published from NHMS_BASINS_ROOT.
# Narrow this only for a targeted rollback / drill (comma-separated model ids).
# NHMS_SCHEDULER_MODEL_IDS=

# --- Pass timing instrumentation (change: instrument-node22-scheduler-pass-timing) ---
# Level controls per-pass timing verbosity:
#   pass      = pass-boundary spans only
#   stage     = pass + per-stage spans (default; always-on health baseline)
#   candidate = pass + stage + per-basin sub-phase spans (opt-in, diagnostic)
# Unknown values fail the pass closed with reason
# `scheduler_timing_level_unrecognised` while still emitting `timing.pass`.
NHMS_SCHEDULER_TIMING_LEVEL=stage    # pass|stage|candidate (default: stage)

# --- Evidence retention (change: instrument-node22-scheduler-pass-timing) --
# Delete pass evidence older than N days first, then evict oldest until total
# size fits under the MB cap. Retention receipts under EVIDENCE_ROOT/retention/
# have their own longer window (see the retention script for defaults).
NHMS_SCHEDULER_EVIDENCE_RETENTION_DAYS=90  # delete pass evidence older than N days
NHMS_SCHEDULER_EVIDENCE_MAX_MB=512    # evict oldest until <= N MB after age pass

# --- Registry cutover declaration (change: node22-db-free-scheduler-state §8) ---
# Consumed by the scheduler's `_load_cutover_declaration` at planning time
# (D8.1: read once per pass, cached per ProductionScheduler lifetime).
# When unset every §8 candidate is treated as `no_declaration` — declared-
# cutover candidates will block with `block_declaration_missing` and
# existing-generation warm-continue remains unaffected.  Publisher-side
# refresh must land the same path (see
# infra/env/compute.scheduler-provider-refresh.env.example).
# NHMS_REGISTRY_CUTOVER_DECLARATION_PATH=/scratch/frd_muziyao/nhms-production/object-store/scheduler/cutover/declaration-last.json
