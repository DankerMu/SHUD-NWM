# 22-side compute/control example for infra/compose.compute.yml.
# Use with:
#   docker compose --env-file infra/env/compute.example -f infra/compose.compute.yml config

NHMS_APP_IMAGE=nhms-app
NHMS_IMAGE_TAG=m22-placeholder
NHMS_CONTAINER_UID=1000
NHMS_CONTAINER_GID=1000
NHMS_SUPPLEMENTAL_GID=1107

NHMS_SERVICE_ROLE=compute_control
NHMS_REQUIRE_SERVICE_ROLE=true
NHMS_AUTH_MODE=production
# Strict production forecast warm-start: forbid cold starts and latest-state
# fallback; require the exact +12h successor checkpoint for each business cycle.
NHMS_REQUIRE_FORECAST_WARM_START=true
UV_CACHE_DIR=/tmp/nhms-uv-cache

# Compute API / archived rollback DB placeholder. The scheduler-once compose
# service does not inherit DATABASE_URL in DB-free mode; keep this only for
# compute-api or an explicit archived rollback drill. Node-22 :55433 is stopped
# and is not an active business DB.
DATABASE_URL=postgresql://nhms_control_rw:change-me@db.internal.example:5432/nhms

WORKSPACE_ROOT=/scratch/frd_muziyao/nhms-production/workspace
OBJECT_STORE_ROOT=/scratch/frd_muziyao/nhms-production/object-store
OBJECT_STORE_PREFIX=s3://nhms-prod
NHMS_OBJECT_STORE_COPYBACK_ROOT=/ghdc/data/nwm/object-store

NHMS_PUBLISHED_ARTIFACT_HOST_ROOT=/ghdc/data/nwm/published
NHMS_PUBLISHED_ARTIFACT_ROOT=/var/lib/nhms/published
NHMS_PUBLISHED_ARTIFACT_URI_PREFIX=published://
NHMS_PUBLISHED_ARTIFACT_S3_BUCKET=nhms-prod
NHMS_PUBLISHED_ARTIFACT_S3_PREFIX=published

# Generic continuous daemon = the production runner (M24). The supported
# business path is `nhms-pipeline plan-production --continuous --submit`
# (-> services/orchestrator/scheduler.py run_continuous); it submits through
# the standalone Slurm gateway (SLURM_GATEWAY_* below). Without --submit,
# plan-production remains dry-run/no-mutation. The legacy run_qhh_* scripts are
# diagnostic-only bring-up fallbacks (M24 §5 / #293), not driven by these vars.
# The NHMS_SCHEDULER_* keys configure that daemon's lock/evidence/roots + cohort.
NHMS_SCHEDULER_LOCK_ROOT=/scratch/frd_muziyao/nhms-production/workspace/scheduler/locks
NHMS_SCHEDULER_DB_FREE_REQUIRED=true
NHMS_SCHEDULER_STATE_BACKEND=file
NHMS_SCHEDULER_LOCK_BACKEND=file
NHMS_SCHEDULER_REGISTRY_BACKEND=file
NHMS_SCHEDULER_REGISTRY_MANIFEST=/scratch/frd_muziyao/nhms-production/object-store/scheduler/registry/manifest-last.json
NHMS_SCHEDULER_CANONICAL_READINESS_BACKEND=file
NHMS_SCHEDULER_CANONICAL_READINESS_INDEX=/scratch/frd_muziyao/nhms-production/object-store/scheduler/canonical-readiness/index-last.json
NHMS_SCHEDULER_JOURNAL_BACKEND=file
NHMS_SCHEDULER_JOURNAL_ROOT=/scratch/frd_muziyao/nhms-production/workspace/scheduler/journal
NHMS_SCHEDULER_STATE_INDEX_BACKEND=file
NHMS_SCHEDULER_STATE_INDEX=/scratch/frd_muziyao/nhms-production/object-store/scheduler/state-index/index-last.json
NHMS_SCHEDULER_EVIDENCE_ROOT=/scratch/frd_muziyao/nhms-production/workspace/scheduler/evidence
NHMS_SCHEDULER_RUNTIME_ROOT=/scratch/frd_muziyao/nhms-production/runtime
NHMS_SCHEDULER_TEMP_ROOT=/scratch/frd_muziyao/nhms-production/tmp
NHMS_SCHEDULER_ALLOWED_ROOTS=/scratch/frd_muziyao/nhms-production/workspace:/scratch/frd_muziyao/nhms-production/object-store:/scratch/frd_muziyao/nhms-production/runtime:/scratch/frd_muziyao/nhms-production/tmp:/ghdc/data/nwm/object-store:/var/lib/nhms/published
NHMS_SCHEDULER_SOURCES=gfs,IFS
# Scheduler hard gate for business candidate/backfill selection.
NHMS_SCHEDULER_ALLOWED_CYCLE_HOURS_UTC=0,12
# Adapter cycle hours only narrow provider discovery/probe breadth; they do not
# decide executable business cycles. Keep them aligned with the scheduler hard
# gate in production so downloads converge on UTC 00/12 by default.
GFS_CYCLE_HOURS_UTC=0,12
IFS_CYCLE_HOURS_UTC=0,12
# Leave empty in production so the DB-free file registry drives every active
# Basins model published from NHMS_BASINS_ROOT. Narrow these only for a targeted
# rollback/drill.
NHMS_SCHEDULER_MODEL_IDS=
NHMS_SCHEDULER_BASIN_IDS=
NHMS_SCHEDULER_INTERVAL_SECONDS=300
NHMS_SCHEDULER_MAX_PASSES=1
# Discovery time is floored by this lag to the prior allowed-cycle boundary
# (for example, with allowed hours 0,12, a lagged 18:01 UTC target floors to 12).
# Adapter cycle-hour env only reduces provider probes; the scheduler hard gate
# remains authoritative for candidate/backfill execution.
NHMS_SCHEDULER_CYCLE_LAG_HOURS=6
# Backfill: each pass scans the past LOOKBACK_HOURS window and re-drives every
# incomplete cycle's full pipeline (completed cycles are skipped, do not consume
# budget). MAX_CYCLES_PER_SOURCE is the per-pass per-source backfill budget.
NHMS_SCHEDULER_LOOKBACK_HOURS=168
NHMS_SCHEDULER_BACKFILL_ENABLED=true
NHMS_SCHEDULER_MAX_CYCLES_PER_SOURCE=8
# Node-27 download -> node-22 scheduler handoff. Keep the scheduler on node-22,
# but require raw manifests written by node-27 to the shared NFS object-store
# before starting downstream stages. When enabled, missing/invalid raw manifests
# block production candidates instead of falling back to node-22 downloads.
NHMS_SCHEDULER_REQUIRE_NFS_RAW_MANIFEST=true
NHMS_SCHEDULER_NFS_RAW_MANIFEST_ROOT=/ghdc/data/nwm/object-store
NHMS_SCHEDULER_NFS_RAW_MANIFEST_PREFIX=s3://nhms
# Slurm compute nodes may not mount /ghdc. The scheduler/control node stages
# node-27 NFS raw into the compute-visible OBJECT_STORE_ROOT before submitting
# convert/forcing/forecast stages.
NHMS_SCHEDULER_STAGE_NFS_RAW_TO_OBJECT_STORE=true
NHMS_SCHEDULER_NFS_RAW_STAGE_ROOT=/scratch/frd_muziyao/nhms-production/object-store
NHMS_SCHEDULER_NFS_RAW_STAGE_PREFIX=s3://nhms-prod
# Node-22 is compute-only in the two-node production topology. It runs SHUD and
# DB-free state_save_qc so forecast warm-start state continues to advance, then
# stops before parse/publish; node-27 owns parse/QC/ingest/display from the
# shared object-store output.
NHMS_ORCHESTRATOR_TERMINAL_STAGE=forecast_state_save_qc
NHMS_REQUIRE_FORECAST_WARM_START=true

NHMS_BASINS_ROOT=/volume/data/nwm/Basins
NHMS_MODEL_ASSET_ROOT=/volume/data/nwm/model-assets
SHUD_EXECUTABLE=/opt/shud/bin/shud

# Slurm gateway = the production submit path. The generic daemon (above) renders
# sbatch from SLURM_GATEWAY_TEMPLATE_DIR and submits via SLURM_GATEWAY_URL; the chain
# never calls sbatch directly. (Diagnostic run_qhh_* scripts bypass this and call
# sbatch on the login node — that is the diagnostic lane, not production.)
SLURM_GATEWAY_URL=http://127.0.0.1:8081
SLURM_GATEWAY_BACKEND=slurm
SLURM_GATEWAY_TEMPLATE_DIR=infra/sbatch
SLURM_GATEWAY_WORKSPACE_DIR=/scratch/frd_muziyao/nhms-production/workspace
# Optional comma-separated unhealthy compute nodes to avoid at submit time.
# Example: SLURM_GATEWAY_EXCLUDE_NODES=cn24
SLURM_GATEWAY_EXCLUDE_NODES=

GFS_NOMADS_BASE_URL=https://nomads.ncep.noaa.gov/pub/data/nccf/com/gfs/prod
IFS_OPEN_DATA_SOURCE=ecmwf

# Download spatial clip bbox: China mainland (18-54N / 73-135E) + 10 degree buffer.
# GFS clips server-side via NOMADS subregion; IFS clips locally via cdo (requires cdo).
NHMS_DOWNLOAD_BBOX_SOUTH=8
NHMS_DOWNLOAD_BBOX_NORTH=64
NHMS_DOWNLOAD_BBOX_WEST=63
NHMS_DOWNLOAD_BBOX_EAST=145

# Shared conda env (cdo + libeccodes) for GRIB clip/read on compute nodes that
# lack system cdo/libeccodes. Injected into each sbatch's PATH/LD_LIBRARY_PATH.
# Path-configurable: currently a user dir; migrate to a project-level shared
# path later by editing only this value (no code change). Leave empty to skip
# injection (only valid where the system already provides cdo+libeccodes).
NHMS_GRIB_ENV_ROOT=/scratch/frd_muziyao/nhms-grib

# §4.5 preflight defaults to NO fence: the control node can't probe a compute
# node's libs without a job, so an empty NHMS_GRIB_ENV_ROOT passes by default
# (assumes the partition provides cdo+eccodes). On a partition whose nodes LACK
# them, either set NHMS_GRIB_ENV_ROOT above (preferred) or set
# NHMS_GRIB_SYSTEM_ECCODES=false to make an empty root fail loud at preflight.
# NHMS_GRIB_SYSTEM_ECCODES=false

# Forecast-data retention: each scheduler pass prunes raw + compute intermediates
# whose cycle_time is older than NHMS_RETENTION_DAYS. Published artifacts and
# static grids are always preserved. Opt-in by design; for first production runs
# keep NHMS_RETENTION_DRY_RUN=true to inspect the plan, then set it false to
# actually delete.
# INVARIANT: NHMS_RETENTION_DAYS * 24 must stay > NHMS_SCHEDULER_LOOKBACK_HOURS,
# else backfill repeatedly retries a cycle retention already deleted
# (currently 14*24=336 > 168 -- safe).
NHMS_RETENTION_ENABLED=true
NHMS_RETENTION_DRY_RUN=false
NHMS_RETENTION_DAYS=14
