{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NHMS Archive Completeness Receipt",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "generated_at", "outcome", "coverage_bounds", "windows", "salvage_selectors"],
      "properties": {
        "schema_version": {"const": "1.1"},
        "generated_at": {"type": "string", "format": "date-time"},
        "outcome": {"const": "complete"},
        "coverage_bounds": {"$ref": "#/definitions/window"},
        "windows": {"$ref": "#/definitions/complete_subject_verdicts"},
        "salvage_selectors": {"type": "array", "maxItems": 0, "items": {"$ref": "#/definitions/selector"}}
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "generated_at", "outcome", "coverage_bounds", "windows", "salvage_selectors"],
      "properties": {
        "schema_version": {"const": "1.1"},
        "generated_at": {"type": "string", "format": "date-time"},
        "outcome": {"const": "incomplete"},
        "coverage_bounds": {"$ref": "#/definitions/window"},
        "windows": {"$ref": "#/definitions/incomplete_subject_verdicts"},
        "salvage_selectors": {"type": "array", "items": {"$ref": "#/definitions/selector"}}
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "generated_at", "outcome", "refusal_reason"],
      "properties": {
        "schema_version": {"const": "1.1"},
        "generated_at": {"type": "string", "format": "date-time"},
        "outcome": {"const": "blocked"},
        "refusal_reason": {"$ref": "#/definitions/blocked_reason"},
        "detail": {"$ref": "#/definitions/detail"}
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "generated_at", "outcome", "error_reason"],
      "properties": {
        "schema_version": {"const": "1.1"},
        "generated_at": {"type": "string", "format": "date-time"},
        "outcome": {"const": "indeterminate"},
        "error_reason": {"const": "UNEXPECTED_AUDIT_ERROR"},
        "detail": {"$ref": "#/definitions/detail"}
      }
    }
  ],
  "definitions": {
    "subject_verdicts": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/definitions/subject_verdict"}
    },
    "complete_subject_verdicts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "allOf": [
          {"$ref": "#/definitions/subject_verdict"},
          {"type": "object", "required": ["verdict"], "properties": {"verdict": {"const": "complete"}}}
        ]
      }
    },
    "incomplete_subject_verdicts": {
      "allOf": [
        {"$ref": "#/definitions/subject_verdicts"},
        {
          "contains": {
            "type": "object",
            "required": ["verdict"],
            "properties": {"verdict": {"enum": ["pending-archive", "gap"]}}
          }
        }
      ]
    },
    "blocked_reason": {
      "enum": [
        "CONFIG_INVALID",
        "EMPTY_INVENTORY",
        "OBJECT_URI_PREFIX_MISMATCH",
        "EVIDENCE_BLOCKED",
        "RESOURCE_BOUND_EXCEEDED",
        "RECEIPT_INVALID"
      ]
    },
    "detail": {"type": "string", "minLength": 1, "maxLength": 512},
    "subject_verdict": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "allOf": [{"$ref": "#/definitions/coverage_verdict_contract"}],
          "required": ["lane", "subject", "window", "coverage", "verdict"],
          "properties": {
            "lane": {"const": "forcing"},
            "subject": {
              "type": "object",
              "additionalProperties": false,
              "required": ["forcing_version_id"],
              "properties": {"forcing_version_id": {"type": "string", "minLength": 1}}
            },
            "window": {"$ref": "#/definitions/window"},
            "coverage": {"$ref": "#/definitions/coverage_mechanism"},
            "verdict": {"$ref": "#/definitions/verdict"},
            "evidence": {"$ref": "#/definitions/evidence"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "allOf": [{"$ref": "#/definitions/coverage_verdict_contract"}],
          "required": ["lane", "subject", "window", "coverage", "verdict"],
          "properties": {
            "lane": {"const": "runs"},
            "subject": {
              "type": "object",
              "additionalProperties": false,
              "required": ["run_id"],
              "properties": {"run_id": {"type": "string", "minLength": 1}}
            },
            "window": {"$ref": "#/definitions/window"},
            "coverage": {"$ref": "#/definitions/coverage_mechanism"},
            "verdict": {"$ref": "#/definitions/verdict"},
            "evidence": {"$ref": "#/definitions/evidence"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "allOf": [{"$ref": "#/definitions/state_coverage_verdict_contract"}],
          "required": ["lane", "subject", "window", "coverage", "verdict"],
          "properties": {
            "lane": {"const": "states"},
            "subject": {
              "type": "object",
              "additionalProperties": false,
              "required": ["state_id"],
              "properties": {"state_id": {"type": "string", "minLength": 1}}
            },
            "window": {"$ref": "#/definitions/window"},
            "coverage": {"$ref": "#/definitions/coverage_mechanism"},
            "verdict": {"$ref": "#/definitions/verdict"},
            "evidence": {"$ref": "#/definitions/evidence"}
          }
        }
      ]
    },
    "coverage_mechanism": {
      "enum": ["product-archive", "db-export", "hot-object-store", "none"]
    },
    "coverage_verdict_contract": {
      "oneOf": [
        {
          "required": ["coverage", "verdict"],
          "properties": {
            "coverage": {"enum": ["product-archive", "db-export", "hot-object-store"]},
            "verdict": {"const": "complete"}
          }
        },
        {
          "required": ["coverage", "verdict"],
          "properties": {
            "coverage": {"const": "hot-object-store"},
            "verdict": {"const": "pending-archive"}
          }
        },
        {
          "required": ["coverage", "verdict"],
          "properties": {
            "coverage": {"const": "none"},
            "verdict": {"const": "gap"}
          }
        }
      ]
    },
    "state_coverage_verdict_contract": {
      "oneOf": [
        {
          "required": ["coverage", "verdict"],
          "properties": {
            "coverage": {"enum": ["product-archive", "hot-object-store"]},
            "verdict": {"const": "complete"}
          }
        },
        {
          "required": ["coverage", "verdict"],
          "properties": {
            "coverage": {"const": "hot-object-store"},
            "verdict": {"const": "pending-archive"}
          }
        },
        {
          "required": ["coverage", "verdict"],
          "properties": {
            "coverage": {"const": "none"},
            "verdict": {"const": "gap"}
          }
        }
      ]
    },
    "verdict": {
      "enum": ["complete", "pending-archive", "gap"]
    },
    "evidence": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {
        "start": {"type": "string", "format": "date-time"},
        "end": {"type": "string", "format": "date-time"}
      }
    },
    "selector": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["table", "identity", "window"],
          "properties": {
            "table": {"const": "met.forcing_station_timeseries"},
            "identity": {
              "type": "object",
              "additionalProperties": false,
              "required": ["forcing_version_id"],
              "properties": {"forcing_version_id": {"type": "string", "minLength": 1}}
            },
            "window": {"$ref": "#/definitions/window"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["table", "identity", "window"],
          "properties": {
            "table": {"const": "hydro.river_timeseries"},
            "identity": {
              "type": "object",
              "additionalProperties": false,
              "required": ["run_id"],
              "properties": {"run_id": {"type": "string", "minLength": 1}}
            },
            "window": {"$ref": "#/definitions/window"}
          }
        }
      ]
    }
  }
}
