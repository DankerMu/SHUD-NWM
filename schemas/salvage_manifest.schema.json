{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NHMS DB Export Salvage Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "provenance", "generated_at", "source_database", "exports"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "provenance": {"const": "db-export"},
    "generated_at": {"type": "string", "format": "date-time"},
    "source_database": {
      "type": "object",
      "additionalProperties": false,
      "required": ["database", "instance_id"],
      "properties": {
        "database": {"type": "string", "minLength": 1},
        "instance_id": {"type": "string", "minLength": 1}
      }
    },
    "exports": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["selector", "exported_row_count", "columns", "object"],
        "properties": {
          "selector": {"$ref": "#/definitions/selector"},
          "exported_row_count": {"type": "integer", "minimum": 0},
          "columns": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
          "object": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "sha256", "size_bytes"],
            "properties": {
              "path": {"allOf": [{"$ref": "#/definitions/safe_relative_path"}, {"pattern": "^db-export/(?:[^/]+/)*[^/]+\\.csv\\.zst$"}]},
              "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
              "size_bytes": {"type": "integer", "minimum": 0}
            }
          }
        }
      }
    }
  },
  "definitions": {
    "selector": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["table", "identity", "window"],
          "properties": {
            "table": {"const": "met.forcing_station_timeseries"},
            "identity": {
              "type": "object",
              "additionalProperties": false,
              "required": ["forcing_version_id"],
              "properties": {"forcing_version_id": {"type": "string", "minLength": 1}}
            },
            "window": {"$ref": "#/definitions/window"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["table", "identity", "window"],
          "properties": {
            "table": {"const": "hydro.river_timeseries"},
            "identity": {
              "type": "object",
              "additionalProperties": false,
              "required": ["run_id"],
              "properties": {"run_id": {"type": "string", "minLength": 1}}
            },
            "window": {"$ref": "#/definitions/window"}
          }
        }
      ]
    },
    "window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {
        "start": {"type": "string", "format": "date-time"},
        "end": {"type": "string", "format": "date-time"}
      }
    },
    "safe_relative_path": {
      "type": "string",
      "pattern": "^(?!/)(?![A-Za-z]:/)(?!.*(?:^|/)(?:\\.{1,2})(?:/|$))(?!.*//)(?!.*[\\\\\\u0000-\\u001F\\u007F])[^/]+(?:/[^/]+)*$"
    }
  }
}
