{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NHMS Archive Rebuild Drill Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "generated_at", "verdict", "staging_database", "coverage"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "generated_at": {"type": "string", "format": "date-time"},
    "verdict": {"enum": ["PASS", "FAIL"]},
    "staging_database": {
      "type": "object",
      "additionalProperties": false,
      "required": ["database", "schema", "instance_id"],
      "properties": {
        "database": {"type": "string", "minLength": 1},
        "schema": {"type": "string", "minLength": 1},
        "instance_id": {"type": "string", "minLength": 1}
      }
    },
    "coverage": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source", "window"],
        "properties": {
          "source": {"enum": ["forcing", "runs", "db-export"]},
          "window": {"$ref": "#/definitions/window"}
        }
      }
    },
    "comparisons": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cycles", "selectors", "counts"],
      "properties": {
        "cycles": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "selectors": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "counts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["item", "expected", "actual"],
            "properties": {
              "item": {"type": "string", "minLength": 1},
              "expected": {"type": "integer", "minimum": 0},
              "actual": {"type": "integer", "minimum": 0}
            }
          }
        }
      }
    },
    "differences": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["item", "expected", "actual"],
        "properties": {
          "item": {"type": "string", "minLength": 1},
          "expected": {},
          "actual": {}
        }
      }
    }
  },
  "definitions": {
    "window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {
        "start": {"type": "string", "format": "date-time"},
        "end": {"type": "string", "format": "date-time"}
      }
    }
  },
  "oneOf": [
    {
      "properties": {
        "verdict": {"const": "PASS"},
        "coverage": {"type": "array", "minItems": 1}
      },
      "required": ["comparisons"],
      "not": {"required": ["differences"]}
    },
    {
      "properties": {
        "verdict": {"const": "FAIL"},
        "coverage": {"type": "array", "minItems": 0}
      },
      "required": ["differences"],
      "not": {"required": ["comparisons"]}
    }
  ]
}
