{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NHMS Product Archive Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "provenance", "identity", "archive", "files", "created_at", "tool_version"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "provenance": {"const": "product-archive"},
    "identity": {"$ref": "#/definitions/archive_identity"},
    "producer": {"$ref": "#/definitions/producer_provenance"},
    "archive": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "manifest_path", "sha256", "size_bytes"],
      "properties": {
        "path": {"allOf": [{"$ref": "#/definitions/safe_relative_path"}, {"pattern": "^(?:forcing|runs|states)/.+/archive\\.tar\\.zst$"}]},
        "manifest_path": {"allOf": [{"$ref": "#/definitions/safe_relative_path"}, {"pattern": "^(?:forcing|runs|states)/.+/manifest\\.json$"}]},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "size_bytes": {"type": "integer", "minimum": 0}
      }
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256", "size_bytes"],
        "properties": {
          "path": {"$ref": "#/definitions/safe_relative_path"},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "size_bytes": {"type": "integer", "minimum": 0}
        }
      }
    },
    "created_at": {"type": "string", "format": "date-time"},
    "tool_version": {"type": "string", "minLength": 1}
  },
  "allOf": [
    {
      "if": {"properties": {"identity": {"properties": {"lane": {"enum": ["forcing", "runs"]}}}}},
      "then": {"required": ["producer"]}
    },
    {
      "if": {"properties": {"identity": {"properties": {"lane": {"const": "forcing"}}}}},
      "then": {"properties": {"producer": {"properties": {"kind": {"const": "forcing-package"}}}}}
    },
    {
      "if": {"properties": {"identity": {"properties": {"lane": {"const": "runs"}}}}},
      "then": {"properties": {"producer": {"properties": {"kind": {"const": "run-manifest"}}}}}
    }
  ],
  "definitions": {
    "safe_segment": {
      "type": "string",
      "pattern": "^(?!\\.{1,2}$)[^/\\\\\\u0000-\\u001F\\u007F]+$"
    },
    "safe_relative_path": {
      "type": "string",
      "pattern": "^(?!/)(?![A-Za-z]:/)(?!.*(?:^|/)(?:\\.{1,2})(?:/|$))(?!.*//)(?!.*[\\\\\\u0000-\\u001F\\u007F])[^/]+(?:/[^/]+)*$"
    },
    "producer_provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind", "subject_id", "manifest_path", "manifest_sha256",
        "start_time", "end_time", "model_id", "basin_version_id"
      ],
      "properties": {
        "kind": {"enum": ["forcing-package", "run-manifest"]},
        "subject_id": {"$ref": "#/definitions/safe_segment"},
        "manifest_path": {"$ref": "#/definitions/safe_relative_path"},
        "manifest_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "start_time": {"type": "string", "format": "date-time"},
        "end_time": {"type": "string", "format": "date-time"},
        "model_id": {"$ref": "#/definitions/safe_segment"},
        "basin_version_id": {"$ref": "#/definitions/safe_segment"}
      }
    },
    "archive_identity": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["lane", "source", "cycle_identity", "cycle_time", "basin_version_id", "model_id"],
          "properties": {
            "lane": {"const": "forcing"},
            "source": {"$ref": "#/definitions/provider_source"},
            "cycle_identity": {"$ref": "#/definitions/safe_segment"},
            "cycle_time": {"$ref": "#/definitions/utc_hourly_cycle_time"},
            "basin_version_id": {"$ref": "#/definitions/safe_segment"},
            "model_id": {"$ref": "#/definitions/safe_segment"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["lane", "source", "cycle_identity", "cycle_time", "run_id"],
          "properties": {
            "lane": {"const": "runs"},
            "source": {"$ref": "#/definitions/provider_source"},
            "cycle_identity": {"$ref": "#/definitions/safe_segment"},
            "cycle_time": {"$ref": "#/definitions/utc_hourly_cycle_time"},
            "run_id": {"$ref": "#/definitions/safe_segment"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["lane", "source", "cycle_identity", "cycle_time", "model_id"],
          "properties": {
            "lane": {"const": "states"},
            "source": {"$ref": "#/definitions/state_source"},
            "cycle_identity": {"$ref": "#/definitions/safe_segment"},
            "cycle_time": {"$ref": "#/definitions/utc_hourly_cycle_time"},
            "model_id": {"$ref": "#/definitions/safe_segment"}
          }
        }
      ]
    },
    "provider_source": {
      "enum": ["gfs", "ERA5", "IFS"]
    },
    "state_source": {
      "enum": ["gfs", "ERA5", "IFS", "legacy-unqualified"]
    },
    "utc_hourly_cycle_time": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:00:00Z$"
    }
  }
}
