{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NHMS Run Status",
  "description": "Status update document reported by NHMS hydrological jobs.",
  "type": "object",
  "additionalProperties": false,
  "required": ["run_id", "status", "timestamp"],
  "properties": {
    "run_id": {
      "description": "Unique hydrological run identifier.",
      "type": "string",
      "minLength": 1
    },
    "identity": {
      "description": "M23 production identity tuple for strict same-run status evidence.",
      "type": "object",
      "additionalProperties": true,
      "required": [
        "run_id",
        "model_id",
        "source",
        "cycle_time",
        "basin_version_id",
        "river_network_version_id",
        "canonical_product_id",
        "forcing_version_id",
        "hydro_run_id",
        "published_manifest_id",
        "pipeline_job_id"
      ],
      "properties": {
        "schema_version": { "type": "string" },
        "contract_id": { "type": "string" },
        "run_id": { "type": "string", "minLength": 1 },
        "model_id": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "source_id": { "type": "string", "minLength": 1 },
        "cycle_time": { "type": "string", "format": "date-time" },
        "basin_version_id": { "type": "string", "minLength": 1 },
        "river_network_version_id": { "type": "string", "minLength": 1 },
        "canonical_product_id": { "type": "string", "minLength": 1 },
        "forcing_version_id": { "type": "string", "minLength": 1 },
        "hydro_run_id": { "type": "string", "minLength": 1 },
        "published_manifest_id": { "type": "string", "minLength": 1 },
        "pipeline_job_id": { "type": "string", "minLength": 1 },
        "pipeline_event_id": { "type": "string" }
      }
    },
    "status": {
      "description": "Hydrological run status.",
      "type": "string",
      "enum": [
        "created",
        "staged",
        "pending",
        "submitted",
        "running",
        "succeeded",
        "blocked",
        "unavailable",
        "partial",
        "parsed",
        "frequency_done",
        "published",
        "failed",
        "cancelled",
        "superseded"
      ]
    },
    "timestamp": {
      "description": "Status observation time in ISO 8601 UTC.",
      "type": "string",
      "format": "date-time"
    },
    "error_code": {
      "type": "string"
    },
    "error_message": {
      "type": "string"
    },
    "exit_code": {
      "type": "integer"
    },
    "progress_pct": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "current_step": {
      "type": "string"
    },
    "log_uri": {
      "type": "string",
      "format": "uri"
    },
    "production_stage": {
      "type": "string",
      "enum": [
        "download",
        "convert",
        "forcing",
        "forecast",
        "parse",
        "q_down_publish",
        "frequency_publish",
        "production_run"
      ]
    },
    "production_status": {
      "type": "string",
      "enum": [
        "pending",
        "ready",
        "running",
        "succeeded",
        "blocked",
        "unavailable",
        "partial",
        "failed",
        "cancelled",
        "superseded"
      ]
    }
  }
}
