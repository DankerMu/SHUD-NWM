{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NHMS Pipeline Job",
  "description": "Pipeline job tracking document for NHMS operations.",
  "type": "object",
  "additionalProperties": false,
  "required": ["job_id", "job_type", "status"],
  "properties": {
    "job_id": {
      "description": "Unique pipeline job identifier.",
      "type": "string",
      "minLength": 1
    },
    "job_type": {
      "description": "Pipeline job type.",
      "type": "string",
      "minLength": 1
    },
    "status": {
      "description": "Pipeline job lifecycle status.",
      "type": "string",
      "enum": ["pending", "submitted", "running", "succeeded", "failed", "cancelled"]
    },
    "run_id": {
      "type": "string"
    },
    "cycle_id": {
      "type": "string"
    },
    "slurm_job_id": {
      "type": "string"
    },
    "stage": {
      "type": "string"
    },
    "submitted_at": {
      "type": "string",
      "format": "date-time"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "finished_at": {
      "type": "string",
      "format": "date-time"
    },
    "exit_code": {
      "type": "integer"
    },
    "retry_count": {
      "type": "integer",
      "minimum": 0,
      "default": 0
    },
    "error_code": {
      "type": "string"
    },
    "error_message": {
      "type": "string"
    },
    "log_uri": {
      "type": "string",
      "format": "uri"
    }
  }
}
