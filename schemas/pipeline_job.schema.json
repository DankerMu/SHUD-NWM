{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NHMS Pipeline Job",
  "description": "Pipeline job tracking document for NHMS operations.",
  "type": "object",
  "additionalProperties": false,
  "required": ["job_id", "job_type", "status"],
  "properties": {
    "job_id": {
      "description": "Unique pipeline job identifier.",
      "type": "string",
      "minLength": 1
    },
    "identity": {
      "description": "M23 production identity tuple bound to this pipeline job or event.",
      "type": "object",
      "additionalProperties": true,
      "required": [
        "run_id",
        "model_id",
        "basin_id",
        "source",
        "cycle_time",
        "basin_version_id",
        "river_network_version_id",
        "canonical_product_id",
        "forcing_version_id",
        "hydro_run_id",
        "published_manifest_id"
      ],
      "properties": {
        "schema_version": { "type": "string" },
        "contract_id": { "type": "string" },
        "run_id": { "type": "string", "minLength": 1 },
        "model_id": { "type": "string", "minLength": 1 },
        "basin_id": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "source_id": { "type": "string", "minLength": 1 },
        "cycle_time": { "type": "string", "format": "date-time" },
        "basin_version_id": { "type": "string", "minLength": 1 },
        "river_network_version_id": { "type": "string", "minLength": 1 },
        "canonical_product_id": { "type": "string", "minLength": 1 },
        "forcing_version_id": { "type": "string", "minLength": 1 },
        "hydro_run_id": { "type": "string", "minLength": 1 },
        "published_manifest_id": { "type": "string", "minLength": 1 },
        "pipeline_job_id": { "type": "string", "minLength": 1 },
        "pipeline_event_id": { "type": "string" }
      }
    },
    "job_type": {
      "description": "Pipeline job type.",
      "type": "string",
      "minLength": 1
    },
    "status": {
      "description": "Pipeline job lifecycle status.",
      "type": "string",
      "enum": [
        "pending",
        "queued",
        "submitted",
        "running",
        "succeeded",
        "partially_failed",
        "failed",
        "submission_failed",
        "permanently_failed",
        "cancelled",
        "skipped"
      ]
    },
    "production_stage": {
      "type": "string",
      "enum": [
        "download",
        "convert",
        "forcing",
        "forecast",
        "parse",
        "q_down_publish",
        "frequency_publish",
        "production_run"
      ]
    },
    "production_status": {
      "type": "string",
      "enum": [
        "pending",
        "ready",
        "running",
        "succeeded",
        "blocked",
        "unavailable",
        "partial",
        "failed",
        "cancelled",
        "superseded"
      ]
    },
    "run_id": {
      "type": "string"
    },
    "cycle_id": {
      "type": "string"
    },
    "model_id": {
      "type": "string"
    },
    "slurm_job_id": {
      "type": "string"
    },
    "array_task_id": {
      "type": "integer",
      "minimum": 0
    },
    "stage": {
      "type": "string"
    },
    "submitted_at": {
      "type": "string",
      "format": "date-time"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "finished_at": {
      "type": "string",
      "format": "date-time"
    },
    "exit_code": {
      "type": "integer"
    },
    "retry_count": {
      "type": "integer",
      "minimum": 0,
      "default": 0
    },
    "error_code": {
      "type": "string"
    },
    "error_message": {
      "type": "string"
    },
    "log_uri": {
      "type": "string",
      "format": "uri"
    }
  }
}
