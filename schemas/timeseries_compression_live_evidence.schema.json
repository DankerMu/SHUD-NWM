        "role_mutated": {"const": false}
      }
    },
    "verdict": {"const": "PASS_TASK_4_5"}
  },
  "allOf": [
    {
      "if": {"required": ["outcome"]},
      "then": {
        "required": ["qualifies_task_4_5", "provenance_state", "failure"],
        "properties": {"schema_version": {"const": "3.0"}, "qualifies_task_4_5": {"const": false}},
        "not": {"required": ["verdict"]}
      },
      "else": {
        "required": ["issue", "node", "mutation_head_sha", "verifier_head_sha", "database_identity", "authorization", "recovery", "preflight", "migration", "selection", "receipts", "sizes", "catalog", "benchmarks", "cleanup", "out_of_scope", "verdict"]
      }
    },
    {
      "if": {"properties": {"schema_version": {"const": "2.0"}}, "required": ["schema_version"]},
      "then": {"not": {"properties": {"qualifies_task_4_5": {"const": true}}, "required": ["qualifies_task_4_5"]}},
      "else": {
        "if": {"not": {"required": ["outcome"]}},
        "then": {
          "required": ["qualifies_task_4_5", "execution", "chronology", "source_manifest"],
          "properties": {"qualifies_task_4_5": {"const": true}},
          "allOf": [
            {"properties": {"authorization": {"required": ["migration_invocations", "dry_run_invocations", "direct_db_bypass_invocations", "repo_path", "remote_identity", "reviewed_mutation_sha", "reviewed_remote_ref"]}}},
            {"properties": {"recovery": {"required": ["invocation"]}}},
            {"properties": {"preflight": {"required": ["schema_dump_list"]}}},
            {"properties": {"migration": {"required": ["first_invocation", "second_invocation"]}}},
            {"properties": {"receipts": {"required": ["dry_run_invocation", "enforce_invocation"]}}}
          ]
        }
      }
    }
